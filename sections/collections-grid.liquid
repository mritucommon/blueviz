        },
        {
          "type": "header",
          "content": "Card Content Customizations"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Card Image",
          "info": "Overrides the Shopify collection featured image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom Title",
          "info": "Leave blank to use Collection title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Card Subheading",
          "default": "COLLECTION"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "CTA Link Text",
          "default": "SHOP"
        },
        {
          "type": "url",
          "id": "custom_link",
          "label": "Custom Link URL",
          "info": "Overrides the default Shopify collection URL"
        },
