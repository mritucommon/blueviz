          "default": "#0b1220"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Title & CTA Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "subheading_color",
          "label": "Subheading Color",
          "default": "#5fa6eb"
        },
        {
          "type": "header",
          "content": "Design Overlay Patterns"
        },
        {
          "type": "select",
          "id": "pattern_type",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
            {
              "value": "diagonal",
              "label": "Diagonal Stripes"
            },
            {
              "value": "horizontal",
              "label": "Horizontal Lines"
            },
            {
              "value": "dot-grid",
              "label": "Dotted Grid"
            },
            {
              "value": "grid",
              "label": "Grid Lines"
            }
          ],
          "default": "diagonal",
          "label": "Background Pattern Type"
        },
        {
          "type": "range",
          "id": "pattern_opacity",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "default": 20,
          "label": "Pattern Opacity"
        },
        {
          "type": "header",
          "content": "Watermark Background Text"
        },
        {
          "type": "text",
          "id": "watermark_text",
          "label": "Watermark Text",
          "info": "Displays giant transparent text in card center (e.g., 'SALE')"
        },
        {
          "type": "color",
          "id": "watermark_color",
          "label": "Watermark Text Color",
          "default": "#ffffff"
        },
        {
          "type": "range",
          "id": "watermark_opacity",
          "min": 0,
          "max": 30,
          "step": 1,
          "unit": "%",
          "default": 4,
          "label": "Watermark Opacity"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections Grid Section",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "title": "T-SHIRTS",
            "subtitle": "COLLECTION",
            "bg_color_gradient": "linear-gradient(180deg, #132742 0%, #0a1729 100%)",
            "bg_color_fallback": "#132742",
            "subheading_color": "#5fa6eb",
            "pattern_type": "diagonal",
            "pattern_opacity": 30
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "JEANS",
            "subtitle": "COLLECTION",
            "bg_color_gradient": "linear-gradient(180deg, #0f1c30 0%, #070e1a 100%)",
            "bg_color_fallback": "#0f1c30",
            "subheading_color": "#4b7fbf",
            "pattern_type": "diagonal",
            "pattern_opacity": 20
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "HOODIES",
            "subtitle": "COLLECTION",
            "bg_color_gradient": "linear-gradient(180deg, #102e5c 0%, #061633 100%)",
            "bg_color_fallback": "#102e5c",
            "subheading_color": "#5e9bf5",
            "pattern_type": "horizontal",
            "pattern_opacity": 25
          }
