{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    margin-top: {{ section.settings.margin_top }}px;
    font-family: var(--font-body-family, 'Outfit', sans-serif);
    overflow: hidden;
    box-sizing: border-box;
  }

  @media screen and (min-width: 750px) {
    .footer-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  /* Main Top Content Wrapper */
  .footer-{{ section.id }} .footer__content-top {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 40px 20px;
    margin-bottom: 60px;
    padding: 0 20px;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    box-sizing: border-box;
  }

  @media screen and (min-width: 600px) {
    .footer-{{ section.id }} .footer__content-top {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .footer-{{ section.id }} .footer__content-top {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 30px;
    }
  }

  /* Brand Info Column */
  .footer__brand-info-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .footer__logo-group-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Outfit', sans-serif;
    font-size: 24px;
    font-weight: 900;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    margin-bottom: 24px;
  }

  .footer__logo-part1-{{ section.id }} {
    color: #ffffff;
  }

  .footer__logo-part2-{{ section.id }} {
    color: #4194ff;
  }

  .footer__description-{{ section.id }} {
    font-size: 13px;
    line-height: 1.6;
    color: {{ section.settings.text_color_muted }};
    margin-bottom: 28px;
    max-width: 280px;
  }

  /* Social Icons */
  .footer__social-list-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .footer__social-link-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 6px;
    background-color: {{ section.settings.badge_bg_color }};
    color: {{ section.settings.badge_text_color }};
    font-family: 'Outfit', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: lowercase;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .footer__social-link-{{ section.id }}:hover {
    background-color: #4194ff;
    color: #ffffff;
    transform: translateY(-2px);
  }

  /* Navigation Columns */
  .footer-block__heading-{{ section.id }} {
    font-family: 'Outfit', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    margin-bottom: 24px;
    line-height: 1;
  }

  .footer-block__menu-list-{{ section.id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-block__menu-item-{{ section.id }} {
    font-size: 13px;
    font-weight: 500;
    color: {{ section.settings.text_color_muted }};
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-block;
  }

  .footer-block__menu-item-{{ section.id }}:hover {
    color: #ffffff;
  }

  .footer-block__menu-item-{{ section.id }}--highlight {
    color: {{ section.settings.highlight_color }} !important;
  }

  .footer-block__menu-item-{{ section.id }}--highlight:hover {
    opacity: 0.85;
  }

  /* Bottom Bar */
  .footer__content-bottom-{{ section.id }} {
    border-top: 1px solid {{ section.settings.divider_color }};
    padding: 30px 20px;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    box-sizing: border-box;
  }

  @media screen and (min-width: 750px) {
    .footer__content-bottom-{{ section.id }} {
      flex-direction: row;
    }
  }

  .footer__copyright-{{ section.id }} {
    font-size: 12px;
    color: {{ section.settings.text_color_muted }};
  }

  /* Payment Badges */
  .footer__payment-list-{{ section.id }} {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .footer__payment-badge-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 12px;
    border-radius: 4px;
    background-color: {{ section.settings.badge_bg_color }};
    color: {{ section.settings.badge_text_color }};
    font-family: 'Outfit', sans-serif;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    user-select: none;
  }
{%- endstyle -%}

<footer class="footer-{{ section.id }}" id="Footer-{{ section.id }}" {{ section.shopify_attributes }}>
  <!-- Top Content (Columns) -->
  <div class="footer__content-top">
    {%- for block in section.blocks -%}
      {%- if block.type == 'payment_badge' -%}{%- continue -%}{%- endif -%}
      <div class="footer-block-{{ section.id }}" {{ block.shopify_attributes }}>
        
        {%- case block.type -%}
          {%- when 'brand_information' -%}
            <div class="footer__brand-info-{{ section.id }}">
              <a href="{{ routes.root_url }}" class="footer__logo-group-{{ section.id }}">
                <span class="footer__logo-part1-{{ section.id }}">{{ block.settings.logo_text_1 | default: 'BB' }}</span>
                <span class="footer__logo-part2-{{ section.id }}">{{ block.settings.logo_text_2 | default: 'BIZ' }}</span>
              </a>

              {%- if block.settings.description != blank -%}
                <p class="footer__description-{{ section.id }}">{{ block.settings.description | escape }}</p>
              {%- endif -%}

              {%- if block.settings.show_social -%}
                <div class="footer__social-list-{{ section.id }}">
                  {%- if block.settings.social_in != blank -%}
                    <a href="{{ block.settings.social_in }}" class="footer__social-link-{{ section.id }}" target="_blank" rel="noopener">in</a>
                  {%- endif -%}
                  {%- if block.settings.social_ig != blank -%}
                    <a href="{{ block.settings.social_ig }}" class="footer__social-link-{{ section.id }}" target="_blank" rel="noopener">ig</a>
                  {%- endif -%}
                  {%- if block.settings.social_tw != blank -%}
                    <a href="{{ block.settings.social_tw }}" class="footer__social-link-{{ section.id }}" target="_blank" rel="noopener">tw</a>
                  {%- endif -%}
                  {%- if block.settings.social_yt != blank -%}
                    <a href="{{ block.settings.social_yt }}" class="footer__social-link-{{ section.id }}" target="_blank" rel="noopener">yt</a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>

          {%- when 'link_list' -%}
            {%- if block.settings.heading != blank -%}
              <div class="footer-block__heading-{{ section.id }}">{{ block.settings.heading | escape }}</div>
            {%- endif -%}

            <ul class="footer-block__menu-list-{{ section.id }}">
              {%- if block.settings.menu != blank -%}
                {%- for link in block.settings.menu.links -%}
                  {%- assign link_title_down = link.title | downcase -%}
                  {%- assign highlight_down = block.settings.highlight_text | downcase -%}
                  <li>
                    <a href="{{ link.url }}" class="footer-block__menu-item-{{ section.id }} {% if link_title_down == highlight_down %}footer-block__menu-item-{{ section.id }}--highlight{% endif %}">
                      {{ link.title }}
                    </a>
                  </li>
                {%- endfor -%}
              {%- else -%}
                <!-- Fallback Mock Menus to match screenshot perfectly if no menu selected -->
                {%- assign mock_links = block.settings.mock_links | split: '|' -%}
                {%- assign highlight_down = block.settings.highlight_text | downcase -%}
                {%- for link_text in mock_links -%}
                  {%- assign link_text_down = link_text | downcase -%}
                  <li>
                    <a href="#" class="footer-block__menu-item-{{ section.id }} {% if link_text_down == highlight_down %}footer-block__menu-item-{{ section.id }}--highlight{% endif %}">
                      {{ link_text }}
                    </a>
                  </li>
                {%- endfor -%}
              {%- endif -%}
            </ul>

        {%- endcase -%}
        
      </div>
    {%- endfor -%}
  </div>

  <!-- Bottom Bar -->
  <div class="footer__content-bottom-{{ section.id }}">
    <div class="footer__copyright-{{ section.id }}">
      &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_text | default: 'BlueBiz. All rights reserved.' }}
    </div>

    {%- if section.settings.show_payment -%}
      <div class="footer__payment-list-{{ section.id }}">
        {%- assign has_payment_blocks = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'payment_badge' -%}
            {%- assign has_payment_blocks = true -%}
            <span class="footer__payment-badge-{{ section.id }}" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: height: 24 }}" alt="{{ block.settings.title }}" height="24" style="object-fit: contain;">
              {%- else -%}
                {{ block.settings.title }}
              {%- endif -%}
            </span>
          {%- endif -%}
        {%- endfor -%}
        
        {%- if has_payment_blocks == false -%}
          {%- assign payment_badges = section.settings.payment_badges | split: '|' -%}
          {%- for badge in payment_badges -%}
            <span class="footer__payment-badge-{{ section.id }}">{{ badge }}</span>
          {%- endfor -%}
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "brand_information",
      "name": "Brand Information",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "logo_text_1",
          "label": "Logo Text Part 1",
          "default": "BB"
        },
        {
          "type": "text",
          "id": "logo_text_2",
          "label": "Logo Text Part 2",
          "default": "BIZ"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Premium streetwear built for the modern generation. Quality in every thread, boldness in every stitch."
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "Show Social Badges"
        },
        {
          "type": "url",
          "id": "social_in",
          "label": "LinkedIn Link",
          "default": "/"
        },
        {
          "type": "url",
          "id": "social_ig",
          "label": "Instagram Link",
          "default": "/"
        },
        {
          "type": "url",
          "id": "social_tw",
          "label": "Twitter Link",
          "default": "/"
        },
        {
          "type": "url",
          "id": "social_yt",
          "label": "YouTube Link",
          "default": "/"
        }
      ]
    },
    {
      "type": "payment_badge",
      "name": "Payment Badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Payment Image",
          "info": "Optional. Will override text if provided."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Payment Name",
          "default": "VISA"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Navigation Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Menu Heading",
          "default": "SHOP"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu"
        },
        {
          "type": "text",
          "id": "mock_links",
          "label": "Mock Links (Fallback)",
          "info": "Separate link titles with | symbol",
          "default": "New Arrivals|T-Shirts|Jeans|Hoodies|Bottoms|Sale"
        },
        {
          "type": "text",
          "id": "highlight_text",
          "label": "Highlight Item Name",
          "info": "Exact title of link to highlight in gold (e.g., 'Sale')",
          "default": "Sale"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Color Schemes"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#070d18"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color_muted",
      "label": "Muted Text Color",
      "default": "#8892a0"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Headings Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Menu Highlight Color",
      "default": "#f5b82e"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge Background Color",
      "default": "#131d30"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#8892a0"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Line Color",
      "default": "#14223d"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "BlueBiz. All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_payment",
      "default": true,
      "label": "Show Payment Badges"
    },
    {
      "type": "text",
      "id": "payment_badges",
      "label": "Payment Badges List",
      "info": "Separate with | symbol",
      "default": "UPI|Visa|Mastercard|RuPay|COD"
    },
    {
      "type": "header",
      "content": "Spacings & Padding"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0,
      "label": "Margin Top"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 80,
      "label": "Padding Top (Desktop)"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 0,
      "label": "Padding Bottom (Desktop)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50,
      "label": "Padding Top (Mobile)"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0,
      "label": "Padding Bottom (Mobile)"
    }
  ]
}
{% endschema %}
